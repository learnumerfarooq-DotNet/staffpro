{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@staffpro/api-clients": ["libs/api-clients/src/index.ts"],
      "@staffpro/api-clients/*": ["libs/api-clients/src/*"],
      "@staffpro/shared-contracts": ["libs/shared-contracts/src/index.ts"],
      "@staffpro/shared-contracts/*": ["libs/shared-contracts/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
